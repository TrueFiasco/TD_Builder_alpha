# Embedding Provider Configuration
# Choose one: voyage, openai, cohere, or local

# Voyage AI (Recommended for technical documentation)
VOYAGE_API_KEY=your_voyage_api_key_here

# OpenAI (Alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# Cohere (Alternative)
# COHERE_API_KEY=your_cohere_api_key_here

# Configuration
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-code-2
FALLBACK_TO_LOCAL=true

# Paths (relative to repo root; populated by `python scripts/fetch_vector_db.py`)
UNIFIED_VECTORDB_PATH=./KB/vector_db
GRAPH_DATA_PATH=./KB/td_knowledge_graph_merged.gpickle

# Performance
MAX_CONCURRENT_API_CALLS=5
QUERY_TIMEOUT_MS=5000
CACHE_ENABLED=true
CACHE_TTL_HOURS=24
