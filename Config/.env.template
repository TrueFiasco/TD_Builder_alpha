# TD Builder — configuration (V0.1.1, key-free / local-only)
#
# The shipped knowledge base was embedded with the local all-MiniLM-L6-v2 model,
# so KB search runs fully offline with no API key. Cloud embedding providers
# (Voyage / OpenAI / Cohere) are intentionally NOT supported in this release —
# their vectors would not match the local-built store and search would break.

# Embedding (local only)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Paths (relative to repo root; KB populated by `python scripts/fetch_vector_db.py`)
UNIFIED_VECTORDB_PATH=./KB/vector_db
GRAPH_DATA_PATH=./KB/knowledge_graph_enhanced.gpickle

# Optional: override the install root if the project is not at its default path
# TD_BUILDER_ROOT=C:/path/to/TD_Builder_Alpha_release_V0.1.1

# Performance
QUERY_TIMEOUT_MS=5000
CACHE_ENABLED=true
CACHE_TTL_HOURS=24
