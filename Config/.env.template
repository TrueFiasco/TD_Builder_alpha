# TD Builder — configuration (v0.2.0, key-free / local-only)
#
# Copy this file to `.env` at the RELEASE ROOT (the folder holding MCP/, KB/,
# Config/, …). Environment variables set in the MCP client config override
# anything in this file.
#
# The shipped knowledge base was embedded with the local all-MiniLM-L6-v2 model,
# so KB search runs fully offline with no API key. Cloud embedding providers are
# not supported — their vectors would not match the local-built store.

# Embedding (local only). KB/manifest.json is authoritative for the model id;
# an EMBEDDING_MODEL that disagrees with the manifest fails the boot on purpose.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Paths (relative paths resolve against the release root;
# KB populated by `python scripts/fetch_vector_db.py`)
UNIFIED_VECTORDB_PATH=KB/vector_db
GRAPH_DATA_PATH=KB/knowledge_graph_enhanced.gpickle

# Optional: absolute path of the release folder, if you relocate/copy it
# TD_BUILDER_ROOT=C:/path/to/TD_Builder

# --- Feedback records (D4) — opt-in, local-only, no network ---
# When enabled, each offline tool call appends a redacted JSONL record under
# ~/.td_builder/feedback/ for your own debugging / issue reports. OFF by default.
# Export a redacted bundle with:  py -3.11 scripts/export_feedback.py
TD_FEEDBACK_ENABLED=false
# TD_FEEDBACK_DIR=                     # override the records dir (default ~/.td_builder/feedback)
# TD_FEEDBACK_RETENTION_DAYS=14        # delete daily record files older than this
# TD_FEEDBACK_MAX_BYTES=8388608        # roll a record file over this size (8 MB)

# --- Live server (td-builder-live) — for reference only ---
# The live server reads ONLY the process environment (the MCP client config's
# "env" block); it does not load this file. Documented here so all knobs are
# listed in one place — see Config/SETTINGS.md.
# TD_API_URL=http://127.0.0.1:9981    # the TD WebServer DAT endpoint
# TD_API_TOKEN=                       # shared-secret token for the TD webserver
# TD_API_TOKEN_FILE=                  # token file path (default: ~/.td_builder/api_token)
