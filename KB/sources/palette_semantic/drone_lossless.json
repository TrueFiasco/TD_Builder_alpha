        "valuechange": "off"
      },
      "parent": "/drone",
      "children": [],
      "inputs": {},
      "extra_files": {
        "text": {
          "content": "2\n*\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0002\u0000\u0000\u0005|# me is this DAT.\n# \n# channel is the Channel object which has changed.\n# sampleIndex is the index of the channel thats changed.\n# val is the numeric value of the changed sample.\n# prev is the previous sample value.\n# \n# Make sure the corresponding toggle is enabled in the CHOP Execute DAT.\n\ntsPar = parent.Rig.par.Translatespeed  \nrsPar = parent.Rig.par.Rotatespeed\n\ndef offToOn(channel, sampleIndex, val, prev):\n    return\n\ndef whileOn(channel, sampleIndex, val, prev):\n    if channel.name == 'forwardBackward':\n        parent.Rig.MoveForwardBackward(op('magnitudes')['forwardBackward'].eval() * tsPar.eval())\n    elif channel.name == 'leftRight':\n        parent.Rig.MoveLeftRight(op('magnitudes')['leftRight'].eval() * tsPar.eval())\n    elif channel.name == 'pitch':\n        parent.Rig.Pitch(op('magnitudes')['pitch'].eval() * rsPar.eval())\n    elif channel.name == 'yaw':\n        parent.Rig.Yaw(op('magnitudes')['yaw'].eval() * -rsPar.eval())\n    elif channel.name == 'up':\n        parent.Rig.MoveUpDown(op('magnitudes')['up'].eval() * tsPar.eval())\n    elif channel.name == 'down':\n        parent.Rig.MoveUpDown(op('magnitudes')['down'].eval() * -tsPar.eval())\n\ndef onToOff(channel, sampleIndex, val, prev):\n    if channel.name == 'reset':\n        parent.Rig.Reset()\n    return\n\ndef whileOff(channel, sampleIndex, val, prev):\n    return\n\ndef valueChange(channel, sampleIndex, val, prev):\n    return",
          "is_binary": false
        }
      }
    },
