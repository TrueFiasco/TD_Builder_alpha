      "extra_files": {
        "text": {
          "content": "2\n*\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0001\u0000\u0000\u0000\u0002\u0000\u0000\u0003\u0017# me - this DAT\n# scriptOp - the OP which is cooking\n\n# press 'Setup Parameters' in the OP to call this function to re-create the parameters.\n#def setupParameters(scriptOp):\n#\treturn\n\n# called whenever custom pulse parameter is pushed\ndef onPulse(par):\n\treturn\n\ndef cook(scriptOp):\n\tscriptOp.clear()\n\tpxChan = scriptOp.inputs[0]['p1_X']\n\tpyChan = scriptOp.inputs[0]['p1_Y']\n\n\tpadUp = scriptOp.appendChan('up')\n\tpadDown = scriptOp.appendChan('down')\n\tpadLeft = scriptOp.appendChan('left')\n\tpadRight = scriptOp.appendChan('right')\n\n\tpadUp[0] = 0\n\tpadDown[0] = 0\n\tpadLeft[0] = 0\n\tpadRight[0] = 0\n\n\tif pxChan[0] > 0.99:\n\t\tpadRight[0] = 1\n\telif pyChan[0] > 0.99:\n\t\tpadUp[0] = 1\n\telif pyChan[0] < 0.01 and not (pxChan[0] < 0.01):\n\t\tpadDown[0] = 1\n\telif pxChan[0] < 0.01:\n\t\tpadLeft[0] = 1\n\n\treturn\n",
          "is_binary": false
        }
      }
    }
