      "inherits": "TOP class",
      "callbacks": [],
      "members": [],
      "methods": [
        {
          "name": "findHeader",
          "signature": "findHeader(key)",
          "return_type": "str",
          "description": "Returns the value of the header with the given key. This method will return a blank string if the header is not found."
        },
        {
          "name": "getHeader",
          "signature": "getHeader(index)",
          "return_type": "tuple",
          "description": "Returns a tuple with the key and value of the header at the given index. This method will throw an error if the index is not valid. The numHeaders member can be used to get the number of valid headers in the file."
        },
        {
          "name": "unload",
          "signature": "unload(cacheMemory=False)",
          "return_type": "None",
          "description": "Unloads the movie and frees its memory usage. The movie will open again next time it cooks, so make sure nothing is still using it to keep it closed."
        },
        {
          "name": "preload",
          "signature": "preload(index)",
          "return_type": "None",
          "description": "Preloads the movie by opening it and pre-reading the first frames. Use the isFullyPreRead member to see if it's ready to play. This is done in a way to minimize impact on the existing playback of the application. If movies are being loaded on startup it's better to just call cook() on the Movie File In"
        }
      ],
