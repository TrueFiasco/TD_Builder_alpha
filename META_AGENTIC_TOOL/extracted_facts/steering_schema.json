{
  "description": "Steering embeddings to guide LLM toward appropriate implementation approach",
  "version": "1.0",

  "approaches": {
    "glsl": {
      "name": "GLSL Shader",
      "operators": ["GLSL TOP", "GLSL Multi TOP", "GLSL MAT", "GLSL POP"],
      "strengths": [
        "Per-pixel operations on images",
        "Real-time GPU-accelerated processing",
        "Procedural texture generation",
        "Custom image effects (blur, distortion, color grading)",
        "Mathematical operations on every pixel",
        "Parallel processing of large data"
      ],
      "indicators": [
        "needs custom image effect",
        "per-pixel processing",
        "procedural noise or patterns",
        "color manipulation",
        "real-time visual effect",
        "GPU acceleration needed",
        "blur, glow, distortion effect",
        "mathematical texture generation",
        "feedback or recursive effects",
        "instancing with custom transforms"
      ],
      "avoid_when": [
        "simple parameter changes suffice",
        "logic or conditionals based on external data",
        "file I/O needed",
        "network communication required",
        "state management across frames"
      ]
    },

    "python": {
      "name": "Python Script",
      "operators": ["Script CHOP", "Script DAT", "Script TOP", "Script SOP", "Execute DAT", "Text DAT"],
      "strengths": [
        "Logic and conditionals",
        "External data integration",
        "File I/O operations",
        "Network communication (OSC, MIDI, TCP, UDP)",
        "State management",
        "Complex data transformations",
        "UI callbacks and interactions",
        "Automation and batch operations"
      ],
      "indicators": [
        "needs logic or conditionals",
        "external data or API",
        "file reading or writing",
        "network communication",
        "state tracking across frames",
        "user interface callbacks",
        "complex data processing",
        "automation task",
        "batch processing",
        "parsing text or JSON"
      ],
      "avoid_when": [
        "simple operator connections suffice",
        "real-time per-pixel image processing",
        "performance-critical visual effects",
        "standard operator exists for the task"
      ]
    },

    "native": {
      "name": "Native Operators",
      "operators": ["All standard TOPs, CHOPs, SOPs, DATs, COMPs, MATs"],
      "strengths": [
        "Pre-built optimized functionality",
        "Visual node-based workflow",
        "Stable and well-tested",
        "Easy to understand and modify",
        "Good performance for standard tasks"
      ],
      "indicators": [
        "standard image operation (resize, blur, composite)",
        "audio processing (filter, mix, analyze)",
        "geometry manipulation (transform, deform)",
        "data table operations",
        "parameter animation",
        "standard rendering"
      ],
      "prefer_when": [
        "a standard operator does exactly what's needed",
        "no custom logic required",
        "maintainability is priority",
        "prototyping or quick iteration"
      ]
    }
  },

  "decision_tree": {
    "question_1": {
      "question": "Does a standard operator exist for this exact task?",
      "yes": "native",
      "no": "question_2"
    },
    "question_2": {
      "question": "Is this per-pixel image processing that needs to run in real-time?",
      "yes": "glsl",
      "no": "question_3"
    },
    "question_3": {
      "question": "Does it need logic, external data, or state management?",
      "yes": "python",
      "no": "question_4"
    },
    "question_4": {
      "question": "Is it GPU-intensive visual/geometric computation?",
      "yes": "glsl",
      "no": "native"
    }
  },

  "semantic_embeddings": {
    "glsl_queries": [
      "custom blur effect on image",
      "procedural noise texture generation",
      "per-pixel color manipulation",
      "real-time image distortion",
      "GPU accelerated processing",
      "fragment shader effect",
      "pixel shader for visual effect",
      "mathematical texture pattern",
      "feedback loop visual effect",
      "custom glow or bloom effect",
      "edge detection shader",
      "chromatic aberration effect",
      "displacement mapping",
      "raymarching SDF shapes"
    ],
    "python_queries": [
      "read data from file",
      "send OSC message",
      "parse JSON data",
      "conditional logic based on input",
      "track state between frames",
      "user interface callback",
      "network TCP communication",
      "batch process multiple files",
      "custom parameter logic",
      "external API integration",
      "MIDI note handling",
      "automation script",
      "data transformation pipeline"
    ],
    "native_queries": [
      "resize image to specific resolution",
      "composite two images together",
      "apply standard blur",
      "mix audio channels",
      "transform geometry position",
      "animate parameter over time",
      "render 3D scene",
      "apply phong material",
      "filter CHOP channels",
      "merge SOP geometry"
    ]
  }
}
