{"id": "EVT-20251217-binary-text-format", "ts": "2025-12-17T11:00:00Z", "agent_id": "claude-opus", "domain": "file_formats", "inputs": {"task": "Fix .text file format for GLSL shaders", "problem": "Shaders not loading - 'A pixel shader must be specified' error"}, "outputs": {"discovery": {"format": "BINARY not TEXT", "structure": {"header": "b'2\n*' (3 bytes)", "metadata": "5 x 4-byte big-endian [1,1,1,1,2]", "length": "4-byte big-endian content length", "content": "UTF-8 encoded text"}, "python_code": "header = b'2\n*'; metadata = struct.pack('>5I', 1, 1, 1, 1, 2); length = struct.pack('>I', len(content)); data = header + metadata + length + content"}, "files_fixed": ["tox_builder/builder.py"], "validated_with": ["thermal_crystalline.tox", "fluid_typography.tox", "data_organism.tox", "recursive_dreamscape.tox"]}, "evidence": [{"source_path": "meta_agentic/tests/output/data_organism.tox.dir/sample_data_organism/pixel_shader.text", "analysis": "hex dump shows binary format", "td_version": "2023.11880"}, {"source_path": "meta_agentic/tests/output/bioluminescent_swarm_after_human_editv4.tox.dir", "analysis": "working human-edited reference", "td_version": "2023.11880"}], "metrics": {"shaders_tested": 4, "all_working": true}, "status": "success", "notes": "Critical discovery: .text files use BINARY format, not line-based TEXT. This affects all DAT content including GLSL shaders. The text-based approach caused shader loading failures.", "schema_version": "1.0", "td_version": "2023.11880", "confidence": 0.98, "problem_ids": []}
{"id": "EVT-20251217-custom-params-artistic-learnings", "ts": "2025-12-17T14:34:01.095893Z", "agent_id": "claude-opus", "domain": "file_formats", "inputs": {"task": "Analyze user feedback on 4 TOX files and research custom parameters", "tox_files": ["thermal_crystalline", "data_organism", "fluid_typography", "recursive_dreamscape"], "user_feedback": {"thermal_crystalline": "Energy causes erratic movement - should control speed not direct value", "data_organism": "Same issue with temp - erratic movement", "fluid_typography": "Works well! Clear param effects, interactive POI", "recursive_dreamscape": "GLSL error: fbm called with vec2, expects vec3"}}, "outputs": {"custom_params_discovery": {"critical_insight": "Custom params NOT in .parm files - created via Python init scripts", "init_script_location": "sample_component/init_script.text", "python_api": ["appendCustomPage", "appendFloat", "appendXY", "appendInt", "appendMenu"], "reference_syntax": "parent().par.ParamName"}, "artistic_learnings": {"parameter_control": "Use normalized params for SPEED/RATE not direct values", "poi_influence": "Multiply by 2.0-5.0 for noticeable effect", "control_connectivity": "Every control must visibly affect output"}, "shader_fix": {"file": "recursive_dreamscape/pixel_shader.text", "error": "fbm(p.xz) - vec2 passed to vec3 function", "fix": "fbm(vec3(p.xz * 0.5 + time * 0.02, time * 0.01))"}, "validated_example": "fluid_typography - clear param effects, interactive POI"}, "evidence": [{"source_path": "meta_agentic/tests/output/4 tox review.txt", "type": "user_feedback"}, {"source_path": "meta_agentic/tests/output/output_images/", "type": "visual_validation"}, {"source_path": "tox_builder/builder_v2.py", "type": "implementation_reference"}], "metrics": {"tox_files_tested": 4, "working_after_edit": 3, "shader_errors_fixed": 1}, "status": "success", "notes": "DPO-style learning: pushing away from erratic movement patterns, pulling toward clear param-to-visual mappings like fluid_typography.", "schema_version": "1.0", "td_version": "2023.11880", "confidence": 0.9, "problem_ids": []}
