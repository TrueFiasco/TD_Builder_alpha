{
  "name": "test_audio_chain",
  "description": "Test audio processing chain",
  "operators": [
    {
      "name": "noise1",
      "type": "noiseCHOP",
      "position": [0, 0],
      "parameters": {
        "amp": 2.0,
        "period": 10,
        "type": "random"
      }
    },
    {
      "name": "math1",
      "type": "mathCHOP",
      "position": [150, 0],
      "inputs": ["noise1"],
      "parameters": {
        "gain": 0.5
      }
    },
    {
      "name": "filter1",
      "type": "filterCHOP",
      "position": [300, 0],
      "inputs": ["math1"],
      "parameters": {
        "filter": "lowpass",
        "cutofflog": 5
      }
    },
    {
      "name": "null1",
      "type": "nullCHOP",
      "position": [450, 0],
      "inputs": ["filter1"]
    }
  ]
}
