{"tool": "td_validate", "args": {"network": {"operators": [{"name": "audioin", "type": "audiofilein", "family": "CHOP", "parameters": {"play": "on", "timeslice": "on", "volume": 1}, "position": [-600, 200]}, {"name": "analysis", "type": "container", "family": "COMP", "palette": "audioAnalysis", "position": [-350, 200]}, {"name": "bands", "type": "null", "family": "CHOP", "position": [-100, 200]}, {"name": "lfo1", "type": "lfo", "family": "CHOP", "parameters": {"wavetype": "sine", "frequency": 0.2, "amp": 0.3, "bias": 0.5, "timeslice": "on", "channelname": "lfoVal"}, "position": [-600, 50]}, {"name": "ramp1", "type": "ramp", "family": "TOP", "position": [-600, -200]}, {"name": "noise1", "type": "noise", "family": "TOP", "parameters": {"type": "perlin3d", "period": {"expr": "op('lfo1')['lfoVal'] * 0.4 + 0.15"}, "amp": 1.5, "format": "rgba8fixed"}, "position": [-350, -200]}, {"name": "comp1", "type": "composite", "family": "TOP", "parameters": {"operand": "add"}, "position": [-100, -200]}, {"name": "glsl1", "type": "glsl", "family": "TOP", "parameters": {"vec0name": "uBrightness", "vec0valuex": {"expr": "op('bands')[0]"}}, "shader": "uniform float uBrightness;\n\nout vec4 fragColor;\n\nvoid main() {\n    vec2 uv = vUV.st;\n    vec4 base = texture(sTD2DInputs[0], uv);\n    float r = texture(sTD2DInputs[0], uv + vec2(0.005, 0.0)).r;\n    float b = texture(sTD2DInputs[0], uv - vec2(0.005, 0.0)).b;\n    vec3 col = vec3(r, base.g, b) * max(uBrightness, 0.3);\n    fragColor = TDOutputSwizzle(vec4(col, base.a));\n}", "position": [150, -200]}, {"name": "level1", "type": "level", "family": "TOP", "parameters": {"brightness1": {"expr": "op('bands')[0] * 0.4 + 0.6"}, "gamma1": 1.2, "contrast": 1.3}, "position": [400, -200]}, {"name": "out_top", "type": "null", "family": "TOP", "position": [650, -200]}, {"name": "info1", "type": "info", "family": "DAT", "parameters": {"op": "glsl1"}, "position": [150, -400]}], "connections": [{"from": "audioin", "to": "analysis/in1"}, {"from": "analysis/out1", "to": "bands"}, {"from": "ramp1", "to": "comp1", "to_input": "0"}, {"from": "noise1", "to": "comp1", "to_input": "1"}, {"from": "comp1", "to": "glsl1"}, {"from": "glsl1", "to": "level1"}, {"from": "level1", "to": "out_top"}]}}}
{"tool": "td_build_project", "args": {"design": {"operators": [{"name": "audioin", "type": "audiofilein", "family": "CHOP", "parameters": {"play": "on", "timeslice": "on", "volume": 1}, "position": [-600, 200]}, {"name": "analysis", "type": "container", "family": "COMP", "palette": "audioAnalysis", "position": [-350, 200]}, {"name": "bands", "type": "null", "family": "CHOP", "position": [-100, 200]}, {"name": "lfo1", "type": "lfo", "family": "CHOP", "parameters": {"wavetype": "sine", "frequency": 0.2, "amp": 0.3, "bias": 0.5, "timeslice": "on", "channelname": "lfoVal"}, "position": [-600, 50]}, {"name": "ramp1", "type": "ramp", "family": "TOP", "position": [-600, -200]}, {"name": "noise1", "type": "noise", "family": "TOP", "parameters": {"type": "perlin3d", "period": {"expr": "op('lfo1')['lfoVal'] * 0.4 + 0.15"}, "amp": 1.5, "format": "rgba8fixed"}, "position": [-350, -200]}, {"name": "comp1", "type": "composite", "family": "TOP", "parameters": {"operand": "add"}, "position": [-100, -200]}, {"name": "glsl1", "type": "glsl", "family": "TOP", "parameters": {"vec0name": "uBrightness", "vec0valuex": {"expr": "op('bands')[0]"}}, "shader": "uniform float uBrightness;\n\nout vec4 fragColor;\n\nvoid main() {\n    vec2 uv = vUV.st;\n    vec4 base = texture(sTD2DInputs[0], uv);\n    float r = texture(sTD2DInputs[0], uv + vec2(0.005, 0.0)).r;\n    float b = texture(sTD2DInputs[0], uv - vec2(0.005, 0.0)).b;\n    vec3 col = vec3(r, base.g, b) * max(uBrightness, 0.3);\n    fragColor = TDOutputSwizzle(vec4(col, base.a));\n}", "position": [150, -200]}, {"name": "level1", "type": "level", "family": "TOP", "parameters": {"brightness1": {"expr": "op('bands')[0] * 0.4 + 0.6"}, "gamma1": 1.2, "contrast": 1.3}, "position": [400, -200]}, {"name": "out_top", "type": "null", "family": "TOP", "position": [650, -200]}, {"name": "info1", "type": "info", "family": "DAT", "parameters": {"op": "glsl1"}, "position": [150, -400]}], "connections": [{"from": "audioin", "to": "analysis/in1"}, {"from": "analysis/out1", "to": "bands"}, {"from": "ramp1", "to": "comp1", "to_input": "0"}, {"from": "noise1", "to": "comp1", "to_input": "1"}, {"from": "comp1", "to": "glsl1"}, {"from": "glsl1", "to": "level1"}, {"from": "level1", "to": "out_top"}]}, "mode": "tox", "project_name": "vj_scene", "output_dir": "{{RUN_DIR}}"}}
