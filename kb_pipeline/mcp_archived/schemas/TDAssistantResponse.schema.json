{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TDAssistantResponse",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": { "type": "string", "enum": ["query", "build_python", "stats"] }
  },
  "allOf": [
    {
      "if": { "properties": { "action": { "const": "query" } } },
      "then": {
        "type": "object",
        "required": ["results"],
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "score", "source", "text", "meta"],
              "properties": {
                "id": { "type": "string" },
                "score": { "type": "number" },
                "source": { "type": "string", "enum": ["docs", "snippets", "palette"] },
                "text": { "type": "string" },
                "meta": { "type": "object" }
              },
              "additionalProperties": true
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "action": { "const": "build_python" } } },
      "then": {
        "type": "object",
        "required": ["script"],
        "properties": {
          "script": { "type": "string" }
        }
      }
    },
    {
      "if": { "properties": { "action": { "const": "stats" } } },
      "then": {
        "type": "object",
        "properties": {
          "stats": { "type": "object" }
        }
      }
    }
  ],
  "additionalProperties": true
}

