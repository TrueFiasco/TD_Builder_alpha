{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TDAssistantRequest",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["query", "build_python", "stats"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "action": { "const": "query" } } },
      "then": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": { "type": "string", "minLength": 1 },
          "n_results": { "type": "integer", "minimum": 1, "maximum": 50, "default": 5 },
          "filters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "sources": {
                "type": "array",
                "items": { "type": "string", "enum": ["docs", "snippets", "palette"] }
              },
              "categories": { "type": "array", "items": { "type": "string" } },
              "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
              "min_popularity": { "type": "number", "minimum": 0, "maximum": 1 },
              "tiers": { "type": "array", "items": { "type": "integer", "minimum": 1, "maximum": 4 } }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "action": { "const": "build_python" } } },
      "then": {
        "type": "object",
        "required": ["network", "target_parent_path"],
        "properties": {
          "network": { "$ref": "./TDNetworkSpec.schema.json" },
          "target_parent_path": { "type": "string", "minLength": 1 },
          "collision_policy": { "type": "string", "enum": ["reuse", "rename", "delete"], "default": "reuse" }
        }
      }
    },
    {
      "if": { "properties": { "action": { "const": "stats" } } },
      "then": {
        "type": "object",
        "properties": {}
      }
    }
  ],
  "additionalProperties": true
}

