{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TDProjectBuildRequest",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["deliver_toe", "deliver_tox", "deliver_python", "deliver_toe_and_python", "deliver_tox_and_python"]
    },
    "network": { "$ref": "TDNetworkSpec.schema.json" },
    "output_path": { "type": "string", "description": "Absolute path for resulting .toe/.tox when applicable" },
    "template_path": { "type": "string", "description": "Optional template .toe/.tox to modify" },
    "td_bin": { "type": "string", "default": "C:\\\\Program Files\\\\Derivative\\\\TouchDesigner\\\\bin" }
  },
  "required": ["mode", "network"]
}

